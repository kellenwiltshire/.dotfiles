window-padding-x = 12
window-padding-y = 30,12
background-opacity = 0.95

# -----------------------------------------------------------------------------

# Font Configuration

# -----------------------------------------------------------------------------

# Values with spaces must be enclosed in quotes

font-size = 12

# -----------------------------------------------------------------------------

keybind = ctrl+d=new_split:auto
keybind = ctrl+e=equalize_splits
keybind = ctrl+x=close_surface
keybind = ctrl+l=goto_split:right
keybind = ctrl+a=goto_split:left

# -----------------------------------------------------------------------------

# Color Theme: Night Owl

# -----------------------------------------------------------------------------

theme = "Night Owl"

# Slowdown mouse scrolling

mouse-scroll-multiplier = 0.95
